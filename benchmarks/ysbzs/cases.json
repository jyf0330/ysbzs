    {
      "id": "C01",
      "title": "Phase1 口径检查",
      "group": "scope",
      "sourceDoc": "docs/01_游戏设计（策划主导）/关卡策划/04_第一阶段10天怪物刷怪闭环设计.md",
      "sourceSection": "设计前提",
      "description": "检查当前口径必须是火伤害闭环+中立召唤流闭环。召唤流不绑定水。水治疗/风牵制/土阻挡应为pending/future。只检查当前有效口径，deprecated/legacyNotes不计。",
      "allowedVerdicts": [
        "PASS",
        "FAIL",
        "GAP_ONLY"
      ],
      "checks": [
        {
          "id": "C01a",
          "label": "召唤流不绑定水",
          "rule": "召唤流描述为中立召唤流闭环，不是水+召唤。仅检查当前有效口径。",
          "verdictLogic": "搜索水+召唤/水系召唤等绑定描述。有→FAIL。仅legacy/历史→PASS。"
        },
        {
          "id": "C01b",
          "label": "水/风/土=pending",
          "rule": "水治疗(泉泉灵)/风牵制(风风灵)/土阻挡(岩岩灵)应为pending",
          "verdictLogic": "代码passive active且非当前口径→FAIL。pending→GAP_ONLY。"
        },
        {
          "id": "C01c",
          "label": "火+召唤=active",
          "rule": "火系和召唤引擎英雄为active",
          "verdictLogic": "status=active→PASS。legacy/design_draft→GAP_ONLY。"
        }
      ]
    },
    {
      "id": "C02",
      "title": "大巴扎商店结构检查",
      "group": "shop",
      "sourceDoc": "docs/01_游戏设计（策划主导）/关卡策划/03_10天商店闭环验证_大巴扎对齐版.md",
      "sourceSection": "七、大巴扎对齐检查",
      "description": "摊位>标签AND>品级>保证位>刷新规则。代码未实现→GAP_ONLY。",
      "allowedVerdicts": [
        "PASS",
        "GAP_ONLY",
        "NOT_IMPLEMENTED"
