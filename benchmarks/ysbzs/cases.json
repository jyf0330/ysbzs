          "verdictLogic": "fixture有定义→检查代码是否实现。未实现→GAP_ONLY。"
        },
        {
          "id": "C02b",
          "label": "标签AND过滤",
          "rule": "filterLogic=AND",
          "verdictLogic": "fixture定义AND。代码未实现→GAP_ONLY。"
        },
        {
          "id": "C02c",
          "label": "品级定价结构",
          "rule": "tier_unified青铜2/白银4/黄金6/钻石8",
          "verdictLogic": "fixture有定义→检查代码GRADE_BASE。"
        },
        {
          "id": "C02d",
          "label": "保证位定义",
          "rule": "Day1召芽灵/Day3/Day5/Day7",
          "verdictLogic": "fixture有定义。代码实现→PASS。否则→GAP_ONLY。"
        },
        {
          "id": "C02e",
          "label": "刷新规则",
          "rule": "首次免费→1→2→3/每天重置",
          "verdictLogic": "代码有refresh→PASS。否则→GAP_ONLY。"
        }
      ]
    },
