{
  "schema": "ysbzs.attackShapes.v2",
  "createdAt": "2026-06-03 23:00 Asia/Tokyo",
  "source": "根据本轮对话：8×8棋盘；S6双叉/S7近身十字不合格；增加S5/T系变形；AI需要自动寻位与指定目标寻优。",
  "board": {
    "rows": 8,
    "cols": 8
  },
  "currentCodeCompatibility": {
    "existingDefinition": "data.js const SD",
    "baseDirection": "right",
    "existingRotator": "actions.js rotCells(cells, dir)",
    "coordinateRule": "cells 为 [rowOffset, colOffset]，相对英雄 H；[0,1] 是英雄右侧一格。",
    "importantImplementationNote": "当前 atkCells 会过滤出界格，AI枚举最佳摆法时建议使用 requiresFullFit=true，即形状必须完整落在8×8内。"
  },
  "designRules": [
    "优先直线、横扫、T、方块、远程T；不做蛇形、Z形、复杂斜线、多拐弯。",
    "S6双叉删除：视觉像漏打中间，不适合作为主攻击块。",
    "S7近身十字删除：更像防御反击，不适合作为主攻击块。",
    "T系是第一版重点，可用宽度、距离、双层、偏移、大前置扩展。",
    "第一版核心池建议只开放 status=core 的12个；reserve 作为中后期/高阶内容。"
  ],
  "aiModes": {
    "autoBest": {
      "description": "玩家不操作时，AI为所有英雄枚举可站位置、方向、形状，选择总分最高组合。",
      "scoreWeights": {
        "hitMonsterCount": 100,
        "killMonsterCount": 80,
        "hitEliteOrCastle": 50,
        "totalDamageValue": 10,
        "moveDistance": -3,
        "wastedEmptyCell": -5,
        "duplicateTargetWithOtherHero": -20
      },
      "searchSuggestion": "每个英雄保留Top 8候选；4英雄最多8^4=4096组合。"
    },
    "forceTarget": {
      "description": "玩家指定某英雄攻击某目标时，先过滤必须命中该目标的候选，再按顺带命中更多怪、击杀更多怪、安全站位、移动距离排序。",
      "priority": [
        "includeClickedTarget",
        "hitMoreMonsters",
        "killMoreMonsters",
        "saferHeroPosition",
        "shorterMoveDistance"
      ]
    }
  },
  "recommendedCoreSn": [
    1,
