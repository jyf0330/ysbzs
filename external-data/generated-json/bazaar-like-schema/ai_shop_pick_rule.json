{
  "schema": "ysbzs.bazaar_like.ai_shop_pick_rule.v1",
  "notes": [
    "AI 自动买卖/刷新规则，用于 10 天跑通、行为测试和自动玩家。",
    "玩家真实 UI 测试仍必须覆盖点击入口 -> 状态变化 -> 日志变化 -> 渲染更新。"
  ],
  "ai_profiles": [
    {
      "profile_id": "default_auto_player",
      "name": "默认自动玩家",
      "priorities": [
        {
          "rule_id": "buy_if_direct_upgrade",
          "score": 100
        },
        {
          "rule_id": "buy_current_hero_bias",
          "score": 80
        },
        {
          "rule_id": "buy_missing_element",
          "score": 60
        },
        {
          "rule_id": "buy_gold_or_diamond_core",
          "score": 90
        },
        {
          "rule_id": "buy_duplicate_for_merge",
          "score": 75
        },
        {
          "rule_id": "skip_if_capacity_full",
          "score": -999
        },
        {
          "rule_id": "avoid_bankrupt_before_boss",
          "score": -60
        },
        {
          "rule_id": "reroll_if_no_buyable_above_score",
          "score": 50
        }
      ]
    }
  ],
  "rules": [
    {
      "rule_id": "buy_if_direct_upgrade",
      "condition": {
        "offer_matches_existing_pal": true,
        "can_merge_or_upgrade": true
      },
      "action": "buy"
    },
    {
      "rule_id": "buy_current_hero_bias",
      "condition": {
        "offer_tags_overlap_hero_bias": true,
        "min_overlap_weight": 20
      },
      "action": "buy"
    },
    {
      "rule_id": "buy_missing_element",
      "condition": {
        "player_missing_element_any": [
          "fire",
          "water",
          "wind",
          "earth"
        ],
        "offer_has_missing_element": true
      },
      "action": "buy"
    },
    {
      "rule_id": "buy_gold_or_diamond_core",
      "condition": {
        "day_min": 5,
        "offer_tier_any": [
          "gold",
          "diamond"
        ],
        "offer_tags_any": [
          "fire",
          "summon",
          "trap",
          "shield",
          "burst"
        ]
      },
      "action": "buy"
    },
    {
      "rule_id": "buy_duplicate_for_merge",
      "condition": {
        "duplicate_count_plus_offer_gte": 2
      },
      "action": "buy"
    },
    {
      "rule_id": "skip_if_capacity_full",
      "condition": {
        "target_zone_full": true
      },
      "action": "skip_buy"
    },
    {
      "rule_id": "avoid_bankrupt_before_boss",
      "condition": {
        "next_encounter_type": "boss",
        "gold_after_buy_less_than": 2
      },
      "action": "skip_buy"
    },
    {
      "rule_id": "reroll_if_no_buyable_above_score",
      "condition": {
        "no_offer_score_gte": 60,
        "reroll_available": true,
        "gold_after_reroll_gte": 1
      },
      "action": "reroll"
    }
  ],
  "fallback_action": {
    "if_can_take_free_reward": "take_free_reward",
    "else": "leave"
  }
}
