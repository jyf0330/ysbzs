{
  "schema": "ysbzs.bazaar_like.economy_rule.v1",
  "notes": [
    "统一管理金币、收入、刷新费、出售、事件费用。",
    "这里是 ysbzs 快节奏经济，不是搬运任何外部游戏完整数值。"
  ],
  "currency": {
    "primary": "gold"
  },
  "start": {
    "gold": 6,
    "income": 3
  },
  "daily_income": {
    "mode": "table_with_formula_fallback",
    "table": {
      "1": 3,
      "2": 4,
      "3": 4,
      "4": 5,
      "5": 6,
      "6": 6,
      "7": 7,
      "8": 7,
      "9": 8,
      "10": 8
    },
    "fallback_formula": "3 + floor(day / 2)"
  },
  "interest": {
    "enabled": true,
    "threshold": 8,
    "gold_per_threshold": 1,
    "max_interest": 2
  },
  "reroll_cost": {
    "source": "merchant_reroll_rule",
    "default_by_poolTier": {
      "1": 1,
      "2": 2,
      "3": 3,
      "4": 4
    }
  },
  "buy_price": {
    "source_priority": [
      "card_master.base_price",
      "tier_curve.default_price",
      "fallback_by_poolTier"
    ],
    "fallback_by_poolTier": {
      "1": 2,
      "2": 4,
      "3": 6,
      "4": 8
    }
  },
  "sell_price": {
    "mode": "half_price_floor_min_1",
    "min": 1,
    "tag_bonus": [
      {
        "tag": "large",
        "bonus_gold": 1,
        "requires_sell_rule_id": "large_pal_buyer"
      }
    ]
  },
  "event_cost": {
    "source": "event_rule.cost",
    "default": {
      "type": "none"
    }
  },
  "capacity": {
    "active": {
      "start": 10,
      "max_soft": 14
    },
    "backpack": {
      "start": 20,
      "max_soft": 30
    },
    "shop": {
      "start": 10,
      "max_soft": 12
    }
  },
  "anti_softlock": {
    "if_gold_less_than_or_equal": 0,
    "free_reward_weight_bonus": 30,
    "cheap_merchant_weight_bonus": 20
  }
}
