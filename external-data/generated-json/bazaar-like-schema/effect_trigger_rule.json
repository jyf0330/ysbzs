{
  "schema": "ysbzs.bazaar_like.effect_trigger_rule.v1",
  "notes": [
    "统一定义：什么时机触发效果。",
    "触发只负责筛选时机和条件，不直接写具体效果。具体效果走 effect_resolve_rule。",
    "第一版覆盖商店、事件、等级、遗物、宠物行动、陷阱、引爆、合成。"
  ],
  "trigger_rules": [
    {
      "trigger_id": "on_shop_enter",
      "display_name": "进入商店",
      "timing": "shop_enter",
      "source_categories": [
        "relic",
        "hero",
        "event_modifier"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "before_shop_roll"
    },
    {
      "trigger_id": "on_shop_offer_roll",
      "display_name": "生成商店商品",
      "timing": "shop_offer_roll",
      "source_categories": [
        "merchant",
        "relic",
        "hero"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "shop_roll_modifier"
    },
    {
      "trigger_id": "on_shop_buy",
      "display_name": "购买商品",
      "timing": "shop_buy",
      "source_categories": [
        "pal",
        "relic",
        "hero",
        "event_modifier"
      ],
      "condition": {
        "target_category_any": [
          "pal"
        ]
      },
      "resolve_queue": "after_buy"
    },
    {
      "trigger_id": "on_shop_reroll",
      "display_name": "刷新商店",
      "timing": "shop_reroll",
      "source_categories": [
        "merchant",
        "relic",
        "hero"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "after_reroll"
    },
    {
      "trigger_id": "on_event_select",
      "display_name": "选择事件",
      "timing": "event_select",
      "source_categories": [
        "event",
        "relic",
        "hero"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "after_event"
    },
    {
      "trigger_id": "on_hero_level_up",
      "display_name": "英雄升级",
      "timing": "hero_level_up",
      "source_categories": [
        "hero",
        "relic"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "level_reward"
    },
    {
      "trigger_id": "on_pal_gain",
      "display_name": "获得宠物",
      "timing": "pal_gain",
      "source_categories": [
        "relic",
        "hero",
        "event_modifier"
      ],
      "condition": {
        "target_category_any": [
          "pal"
        ]
      },
      "resolve_queue": "after_gain_pal"
    },
    {
      "trigger_id": "on_pal_merge",
      "display_name": "合成宠物",
      "timing": "pal_merge",
      "source_categories": [
        "pal",
        "relic",
        "hero"
      ],
      "condition": {
        "target_category_any": [
          "pal"
        ]
      },
      "resolve_queue": "after_merge"
    },
    {
      "trigger_id": "on_battle_start",
      "display_name": "战斗开始",
      "timing": "battle_start",
      "source_categories": [
        "pal",
        "relic",
        "hero"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "battle_start"
    },
    {
      "trigger_id": "on_pal_action",
      "display_name": "宠物行动",
      "timing": "pal_action",
      "source_categories": [
        "pal",
        "relic"
      ],
      "condition": {
        "actor_category_any": [
          "pal"
        ]
      },
      "resolve_queue": "action_modifier"
    },
    {
      "trigger_id": "on_element_apply",
      "display_name": "施加元素",
      "timing": "element_apply",
      "source_categories": [
        "pal",
        "relic",
        "terrain"
      ],
      "condition": {
        "element_any": [
          "fire",
          "water",
          "wind",
          "earth"
        ]
      },
      "resolve_queue": "element_modifier"
    },
    {
      "trigger_id": "on_fire_explode",
      "display_name": "火元素引爆",
      "timing": "element_explode",
      "source_categories": [
        "pal",
        "relic"
      ],
      "condition": {
        "element_any": [
          "fire"
        ]
      },
      "resolve_queue": "explode_modifier"
    },
    {
      "trigger_id": "on_trap_enter",
      "display_name": "踩入陷阱",
      "timing": "terrain_enter",
      "source_categories": [
        "terrain",
        "relic",
        "pal"
      ],
      "condition": {
        "terrain_tags_any": [
          "trap"
        ],
        "actor_side_any": [
          "enemy"
        ]
      },
      "resolve_queue": "terrain_damage"
    },
    {
      "trigger_id": "on_monster_move_step",
      "display_name": "怪物每格移动",
      "timing": "monster_move_step",
      "source_categories": [
        "terrain",
        "relic",
        "pal"
      ],
      "condition": {
        "actor_side_any": [
          "enemy"
        ]
      },
      "resolve_queue": "movement_modifier"
    },
    {
      "trigger_id": "on_battle_win",
      "display_name": "战斗胜利",
      "timing": "battle_win",
      "source_categories": [
        "hero",
        "relic",
        "encounter"
      ],
      "condition": {
        "any": []
      },
      "resolve_queue": "battle_reward"
    }
  ],
  "trigger_order": [
    "before_shop_roll",
    "shop_roll_modifier",
    "after_buy",
    "after_reroll",
    "after_event",
    "level_reward",
    "after_gain_pal",
    "after_merge",
    "battle_start",
    "action_modifier",
    "element_modifier",
    "explode_modifier",
    "movement_modifier",
    "terrain_damage",
    "battle_reward"
  ]
}
